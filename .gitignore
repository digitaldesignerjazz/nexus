# Nexus Project .gitignore
# Comprehensive for Rust, Python, Docker, LaTeX, Node, general dev

# Rust (Grok Launcher, prototypes)
/target/
**/*.rs.bk
Cargo.lock

# Python (AI agents, scripts, monitoring)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv/

# Docker (mesh networking, Yggdrasil, Tenda Nova, containers)
*.log
Dockerfile*
!Dockerfile
.dockerignore

# Node.js / npm (if web dashboards, UIs)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# LaTeX / docs (whitepapers, specs)
*.aux
*.bbl
*.blg
*.log
*.out
*.toc
*.fdb_latexmk
*.fls
*.synctex.gz

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated
.DS_Store
Thumbs.db

# Environment and secrets (privacy critical - Tor/I2P, keys)
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# Build artifacts and large files
*.zip
*.tar.gz
*.rar
build/
dist/

# Project specific (add as needed)
# /prototypes/*/bin/
# /mesh/configs/local/

# Temporary and cache
*.tmp
*.temp
.cache/
